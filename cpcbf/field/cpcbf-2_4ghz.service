[Unit]
Description=CPCBF Field Benchmark — 2.4GHz Track (BLE + WiFi on MKR WiFi 1010)
After=multi-user.target bluetooth.service
Wants=multi-user.target bluetooth.service

[Service]
Type=oneshot
Environment=PYTHONUNBUFFERED=1
ExecStartPre=/bin/sh -c '/usr/bin/hciconfig hci0 up; /usr/bin/hciconfig hci0 piscan'
ExecStart=/usr/bin/python3 __SCRIPT_DIR__/auto_bench.py __SCRIPT_DIR__/role_2_4ghz.json
ExecStopPost=/usr/sbin/rfkill unblock all
ExecStopPost=/bin/systemctl start NetworkManager
StandardOutput=journal
StandardError=journal
RemainAfterExit=no
TimeoutStartSec=infinity

[Install]
WantedBy=multi-user.target
