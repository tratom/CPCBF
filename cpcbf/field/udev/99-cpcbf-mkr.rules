# CPCBF — stable serial-port symlinks for the autonomous field rig.
#
# Each MKR board exposes two different USB PIDs depending on whether it's
# running the sketch or the SAM-BA bootloader. We match BOTH so the
# symlink survives a flash-cycle (touch -> bootloader -> bossac -> sketch).
#
# Verify on first install with `lsusb | grep 2341` — different revisions
# may use different sketch PIDs (some MKR WAN 1300 firmwares use 0x8059).
#
# MKR WiFi 1010
SUBSYSTEM=="tty", ATTRS{idVendor}=="2341", ATTRS{idProduct}=="0054", SYMLINK+="ttyACM_WIFI", MODE="0666"
SUBSYSTEM=="tty", ATTRS{idVendor}=="2341", ATTRS{idProduct}=="8054", SYMLINK+="ttyACM_WIFI", MODE="0666"
# MKR WAN 1300
SUBSYSTEM=="tty", ATTRS{idVendor}=="2341", ATTRS{idProduct}=="0053", SYMLINK+="ttyACM_WAN",  MODE="0666"
SUBSYSTEM=="tty", ATTRS{idVendor}=="2341", ATTRS{idProduct}=="8053", SYMLINK+="ttyACM_WAN",  MODE="0666"
SUBSYSTEM=="tty", ATTRS{idVendor}=="2341", ATTRS{idProduct}=="8059", SYMLINK+="ttyACM_WAN",  MODE="0666"
