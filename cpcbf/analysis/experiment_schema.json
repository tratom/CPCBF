{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experiment Metadata",
  "description": "Metadata for a CPCBF experiment session",
  "type": "object",
  "required": ["scenario_id"],
  "properties": {
    "scenario_id": {
      "type": "string",
      "description": "Unique identifier for the scenario (typically directory name)"
    },
    "test_procedure_description": {
      "type": "string",
      "description": "Description of the test procedure"
    },
    "environmental_description": {
      "type": "string",
      "description": "Description of the physical environment"
    },
    "location": {
      "type": "string",
      "description": "Human-readable location name"
    },
    "test_date": {
      "type": "string",
      "format": "date",
      "description": "Date the test was performed (YYYY-MM-DD)"
    },
    "test_configuration": {
      "type": "object",
      "properties": {
        "technology": {
          "type": "string",
          "enum": ["wifi", "ble", "lora", "zigbee", "ghn", ""]
        },
        "distance_meters": {
          "type": "number",
          "minimum": 0
        },
        "samples_per_scenario": {
          "type": "integer",
          "minimum": 1
        },
        "iteration_duration_minutes": {
          "type": "number",
          "minimum": 0
        },
        "measured_metrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "device_id"],
        "properties": {
          "role": {
            "type": "string"
          },
          "device_id": {
            "type": "string"
          },
          "hardware": {
            "type": "string"
          },
          "ip_address": {
            "type": "string"
          },
          "mac_address": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "dynamic_interference": {
      "type": "object",
      "properties": {
        "pedestrians_observed": {
          "type": "integer",
          "minimum": 0
        },
        "vehicles_observed": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "media_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file_name", "path"],
        "properties": {
          "file_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
