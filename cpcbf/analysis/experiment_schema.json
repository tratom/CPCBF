{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experiment Metadata",
  "description": "Metadata for a CPCBF experiment session (non-derivable fields only)",
  "type": "object",
  "required": ["scenario_id"],
  "properties": {
    "scenario_id": {
      "type": "string",
      "description": "Unique identifier for the scenario (typically directory name)"
    },
    "location": {
      "type": "string",
      "description": "Human-readable location name"
    },
    "environment_type": {
      "type": "string",
      "enum": ["underground_garage", "office", "corridor", "stairwell", "elevator_shaft", "server_room"],
      "description": "Type of physical environment where the test was conducted"
    },
    "test_date": {
      "type": "string",
      "format": "date",
      "description": "Date the test was performed (YYYY-MM-DD)"
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Duration of the test in minutes"
    },
    "distance_meters": {
      "type": "number",
      "minimum": 0,
      "description": "Distance between sender and receiver in meters"
    },
    "test_procedure_description": {
      "type": "string",
      "description": "Description of the test procedure"
    },
    "environmental_description": {
      "type": "string",
      "description": "Description of the physical environment"
    },
    "dynamic_interference": {
      "type": "object",
      "properties": {
        "pedestrians_observed": {
          "type": "integer",
          "minimum": 0
        },
        "vehicles_observed": {
          "type": "integer",
          "minimum": 0
        },
        "vehicles_parked": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "static_interference": {
      "type": "object",
      "description": "Static obstacles between sender and receiver (walls, doors, etc.)",
      "properties": {
        "wall_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of walls between master and peer"
        },
        "walls": {
          "type": "array",
          "description": "Per-wall details, ordered from master to peer",
          "items": {
            "type": "object",
            "required": ["material", "thickness_cm", "distance_from_master_m"],
            "properties": {
              "material": {
                "type": "string",
                "enum": [
                  "concrete",
                  "reinforced_concrete",
                  "brick",
                  "drywall",
                  "plasterboard",
                  "wood",
                  "glass",
                  "metal",
                  "stone",
                  "other"
                ],
                "description": "Primary wall material"
              },
              "thickness_cm": {
                "type": "number",
                "minimum": 0,
                "description": "Wall thickness in centimeters"
              },
              "distance_from_master_m": {
                "type": "number",
                "minimum": 0,
                "description": "Distance of this wall from the master device in meters"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "device_id"],
        "properties": {
          "role": {
            "type": "string"
          },
          "device_id": {
            "type": "string"
          },
          "hardware": {
            "type": "string"
          },
          "local_ip": {
            "type": "string",
            "description": "Device's own IP address"
          },
          "peer_addr": {
            "type": "string",
            "description": "Peer device IP address"
          },
          "peer_mac": {
            "type": "string",
            "description": "Peer device WiFi MAC address"
          },
          "ble_mac_peer": {
            "type": "string",
            "description": "Peer device BLE MAC address"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "media_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file_name", "path"],
        "properties": {
          "file_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
